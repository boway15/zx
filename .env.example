# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=zxs
DB_PASSWORD=zxs123
DB_NAME=zxs

# App
PORT=3000
NODE_ENV=production
DB_SYNC=true
APP_BASE_URL=http://localhost:9080
BUSINESS_HOURS_START=06:00
BUSINESS_HOURS_END=23:00

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=change-me-admin-secret
ADMIN_JWT_EXPIRES_IN=1d
ADMIN_DEFAULT_PASSWORD=admin123

# WeChat (leave empty for dev mock mode)
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
WECHAT_NOTIFY_URL=https://your-domain.com/api/orders/wechat/notify
WECHAT_MOCK_PAY=true

# TTLock (leave empty for dev mock mode)
TTLOCK_CLIENT_ID=
TTLOCK_CLIENT_SECRET=
TTLOCK_USERNAME=
TTLOCK_PASSWORD=
TTLOCK_API_BASE=https://cnapi.ttlock.com
TTLOCK_LOCK_ID=0
TTLOCK_GATEWAY_ID=0
TTLOCK_MOCK_UNLOCK=true

# Docker
HTTP_PORT=9080
